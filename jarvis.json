{
    "project": {
        "name": "JARVIS",
        "stack": [
            "Electron",
            "React",
            "FastAPI",
            "Claude API",
            "Ollama",
            "CodeLlama",
            "Python",
            "WebSocket"
        ],
        "current_focus": "Proactive developer intelligence \u2014 zero search paradigm",
        "repo_root": "/src"
    },
    "decisions": [
        {
            "what": "AI engine for proactive gate",
            "chose": "Ollama / CodeLlama",
            "rejected": "Claude API",
            "reason": "Gate runs 50+ times per hour \u2014 must be free and local"
        },
        {
            "what": "AI engine for error diagnosis",
            "chose": "gemini-2.5-flash",
            "rejected": "llama-3.3-70b-versatile",
            "reason": "Error diagnosis is user-facing quality \u2014 needs deep reasoning"
        },
        {
            "what": "AI engine for summaries and commit messages",
            "chose": "llama-3.3-70b-versatile",
            "rejected": "gemini-2.5-flash",
            "reason": "Structured short output \u2014 Groq matches Gemini quality at lower latency and cost"
        },
        {
            "what": "Project memory format",
            "chose": "jarvis.json structured schema",
            "rejected": "free-text notes",
            "reason": "Structured fields prevent hallucination \u2014 Claude reads schema not prose"
        },
        {
            "what": "Local secure mode model",
            "chose": "CodeLlama via Ollama",
            "rejected": "Claude API in local mode",
            "reason": "Zero bytes leave machine in secure mode"
        }
    ],
    "open_questions": [
        "Proactive gate cooldown window \u2014 5 minutes or 10 minutes?",
        "Max tool iterations before hard stop \u2014 10 or 15?",
        "Surface card auto-dismiss timer \u2014 8 seconds or 12 seconds?"
    ],
    "rejected_approaches": [
        "Claude API for proactive gate",
        "Sonnet for all tasks",
        "Free-text project memory",
        "localStorage for state persistence"
    ],
    "ai_config": {
        "mode": "local",
        "cloud_model": "gemini-2.5-flash",
        "fallback_model": "llama-3.3-70b-versatile",
        "local_model": "ollama/qwen3.5:cloud",
        "max_tool_iterations": 10,
        "system_prompt_version": "v1"
    },
    "websocket": {
        "port": 8765,
        "events_send": [
            "user_query",
            "mode_change",
            "surface_dismissed"
        ],
        "events_receive": [
            "jarvis_stream_chunk",
            "jarvis_surface",
            "jarvis_response",
            "jarvis_mode_ack",
            "jarvis_error"
        ]
    },
