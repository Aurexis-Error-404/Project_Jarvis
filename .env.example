# ─────────────────────────────────────────────
# JARVIS — Environment Configuration Template
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── AI Mode ───────────────────────────────────
# Options: local | cloud | groq | gemini
# Default: local  (Ollama/CodeLlama, zero API cost)
# Switch to cloud/groq/gemini only for testing
AI_MODE=local


# ── Google Gemini ─────────────────────────────
# Used when AI_MODE=gemini
# Get key: https://aistudio.google.com/app/apikey
# Model: gemini-2.0-flash | gemini-1.5-pro
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Groq ──────────────────────────────────────
# Used when AI_MODE=groq  (ultra-low latency cloud)
# Get key: https://console.groq.com/keys
# Model: llama-3.3-70b-versatile | mixtral-8x7b-32768
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (Local) ────────────────────────────
# Used when AI_MODE=local  (default — gate always uses this)
# Gate model: codellama  (runs 50+ times/hour — must stay local)
# Run: ollama serve  →  ollama pull codellama
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=codellama

# ── Server Ports (DO NOT CHANGE) ─────────────
WEBSOCKET_PORT=8765
FASTAPI_PORT=8000

# ── Project ───────────────────────────────────
JARVIS_JSON_PATH=./jarvis.json
